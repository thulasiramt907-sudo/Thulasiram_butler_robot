<?xml version="1.0"?>
<robot name="butler_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find butler_robot)/urdf/materials.xacro"/>

  <xacro:property name="base_width"       value="0.35"/>
  <xacro:property name="base_length"      value="0.40"/>
  <xacro:property name="base_height"      value="0.20"/>
  <xacro:property name="base_mass"        value="5.0"/>
  <xacro:property name="wheel_radius"     value="0.05"/>
  <xacro:property name="wheel_width"      value="0.04"/>
  <xacro:property name="wheel_mass"       value="0.5"/>
  <xacro:property name="wheel_separation" value="0.28"/>
  <xacro:property name="caster_radius"    value="0.025"/>
  <xacro:property name="caster_mass"      value="0.1"/>
  <xacro:property name="tray_width"       value="0.30"/>
  <xacro:property name="tray_length"      value="0.35"/>
  <xacro:property name="tray_height"      value="0.02"/>
  <xacro:property name="tray_mass"        value="0.3"/>
  <xacro:property name="tray_pole_height" value="0.40"/>
  <xacro:property name="lidar_radius"     value="0.035"/>
  <xacro:property name="lidar_height"     value="0.05"/>
  <xacro:property name="lidar_mass"       value="0.1"/>

  <!-- Inertia macros -->
  <xacro:macro name="box_inertia" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${(1/12)*mass*(y*y+z*z)}" ixy="0" ixz="0"
               iyy="${(1/12)*mass*(x*x+z*z)}" iyz="0"
               izz="${(1/12)*mass*(x*x+y*y)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="mass r h">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${(1/12)*mass*(3*r*r+h*h)}" ixy="0" ixz="0"
               iyy="${(1/12)*mass*(3*r*r+h*h)}" iyz="0"
               izz="${(1/2)*mass*r*r}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="mass r">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${(2/5)*mass*r*r}" ixy="0" ixz="0"
               iyy="${(2/5)*mass*r*r}" iyz="0"
               izz="${(2/5)*mass*r*r}"/>
    </inertial>
  </xacro:macro>

  <!-- Wheel macro -->
  <xacro:macro name="wheel" params="name x_pos y_pos">
    <link name="${name}_wheel">
      <visual>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="rubber_black"/>
      </visual>
      <collision>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <xacro:cylinder_inertia mass="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>
    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_wheel"/>
      <origin xyz="${x_pos} ${y_pos} ${-base_height/2}" rpy="${pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>
    <gazebo reference="${name}_wheel">
      <material>Gazebo/Black</material>
      <mu1>1.0</mu1><mu2>1.0</mu2>
      <kp>500000</kp><kd>10</kd>
    </gazebo>
  </xacro:macro>

  <!-- Caster macro -->
  <xacro:macro name="caster" params="name x_pos y_pos">
    <link name="${name}_caster">
      <visual>
        <geometry><sphere radius="${caster_radius}"/></geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <geometry><sphere radius="${caster_radius}"/></geometry>
      </collision>
      <xacro:sphere_inertia mass="${caster_mass}" r="${caster_radius}"/>
    </link>
    <joint name="${name}_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="${name}_caster"/>
      <origin xyz="${x_pos} ${y_pos} ${-base_height/2 - wheel_radius + caster_radius}" rpy="0 0 0"/>
    </joint>
    <gazebo reference="${name}_caster">
      <material>Gazebo/Grey</material>
      <mu1>0.0</mu1><mu2>0.0</mu2>
    </gazebo>
  </xacro:macro>

  <!-- Base footprint -->
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius + base_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- Base link -->
  <link name="base_link">
    <visual>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
    </collision>
    <xacro:box_inertia mass="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}"/>
  </link>
  <gazebo reference="base_link"><material>Gazebo/White</material></gazebo>

  <!-- Wheels -->
  <xacro:wheel name="left"  x_pos="0.0" y_pos="${ wheel_separation/2}"/>
  <xacro:wheel name="right" x_pos="0.0" y_pos="${-wheel_separation/2}"/>

  <!-- Casters -->
  <xacro:caster name="front" x_pos="${ base_length/2 - caster_radius}" y_pos="0.0"/>
  <xacro:caster name="rear"  x_pos="${-base_length/2 + caster_radius}" y_pos="0.0"/>

  <!-- Tray pole -->
  <link name="tray_pole">
    <visual>
      <geometry><cylinder radius="0.02" length="${tray_pole_height}"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.02" length="${tray_pole_height}"/></geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.2" r="0.02" h="${tray_pole_height}"/>
  </link>
  <joint name="tray_pole_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="tray_pole"/>
    <origin xyz="0 0 ${base_height/2 + tray_pole_height/2}" rpy="0 0 0"/>
  </joint>
  <gazebo reference="tray_pole"><material>Gazebo/Grey</material></gazebo>

  <!-- Tray -->
  <link name="tray">
    <visual>
      <geometry><box size="${tray_length} ${tray_width} ${tray_height}"/></geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <geometry><box size="${tray_length} ${tray_width} ${tray_height}"/></geometry>
    </collision>
    <xacro:box_inertia mass="${tray_mass}" x="${tray_length}" y="${tray_width}" z="${tray_height}"/>
  </link>
  <joint name="tray_joint" type="fixed">
    <parent link="tray_pole"/>
    <child  link="tray"/>
    <origin xyz="0 0 ${tray_pole_height/2 + tray_height/2}" rpy="0 0 0"/>
  </joint>
  <gazebo reference="tray"><material>Gazebo/Grey</material></gazebo>

  <!-- Lidar -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="${lidar_radius}" length="${lidar_height}"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="${lidar_radius}" length="${lidar_height}"/></geometry>
    </collision>
    <xacro:cylinder_inertia mass="${lidar_mass}" r="${lidar_radius}" h="${lidar_height}"/>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0 0 ${base_height/2 + tray_pole_height + tray_height + lidar_height/2 + 0.02}" rpy="0 0 0"/>
  </joint>
  <gazebo reference="lidar_link">
    <material>Gazebo/Black</material>
    <sensor type="ray" name="lidar_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle> 3.14159</max_angle>
          </horizontal>
        </scan>
        <range><min>0.12</min><max>10.0</max><resolution>0.01</resolution></range>
        <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
      </ray>
      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=/scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Differential drive plugin - ROS2 Humble compatible -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <remapping>cmd_vel:=/cmd_vel</remapping>
        <remapping>odom:=/odom</remapping>
      </ros>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_diameter>${2 * wheel_radius}</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>

</robot>
